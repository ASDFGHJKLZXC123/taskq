# Environment: dev | prod
TASKQ_ENV=dev

# Postgres DSN
TASKQ_DATABASE_URL=postgresql://taskq:taskq@localhost:5432/taskq

# asyncpg pool sizing (pool_max >= TASKQ_CONCURRENCY + 2)
TASKQ_DB_POOL_MIN=2
TASKQ_DB_POOL_MAX=10

# Worker
TASKQ_CONCURRENCY=4
TASKQ_QUEUE=default
TASKQ_POLL_INTERVAL_S=0.5

# Admin auth (prod + unset = refuse to start; dev + unset = auth disabled with warning)
TASKQ_ADMIN_TOKEN=

# Webhook signing
TASKQ_WEBHOOK_SIGNING_SECRET=dev-secret-change-me

# Reaper (runs in API service only)
TASKQ_REAP_ENABLED=true
TASKQ_REAP_INTERVAL_S=300
TASKQ_REAP_BATCH=1000
TASKQ_REAP_RETENTION_DAYS=7

# httpx timeouts for the webhook handler
TASKQ_HTTP_CONNECT_TIMEOUT_S=5
TASKQ_HTTP_READ_TIMEOUT_S=25

# Demo subscriber random failure rate (0.0 = off; tests prefer deterministic flags)
TASKQ_FAIL_RATE=0.0

# Hard payload cap enforced by enqueue
TASKQ_PAYLOAD_MAX_BYTES=65536

# Logging
TASKQ_LOG_LEVEL=INFO
